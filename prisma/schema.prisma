datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client-js"
}

model Lead {
  id               String   @id @default(cuid())

  // Contact info
  firstName        String
  lastName         String
  phone            String
  email            String
  address          String
  city             String
  zip              String

  // Project info
  trade            String
  surface          Int
  message          String?
  budget           String?
  urgency          String?
  propertyType     String?

  // Tracking (auto-captured)
  sourceUrl        String?
  utmSource        String?
  utmMedium        String?
  utmCampaign      String?
  device           String?
  cityGeo          String?

  // Dispatch
  dispatcher       String?
  dispatcherStatus Boolean  @default(false)

  // RGPD
  createdAt        DateTime @default(now())
  expiresAt        DateTime
}
